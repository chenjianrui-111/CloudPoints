---
import MusicBars from './MusicBars.astro';
import WaitlistForm from './WaitlistForm.tsx';
---

<section class="flex flex-col items-center px-6 pt-16 pb-10">
  <div class="flex flex-col items-center max-w-lg w-full">
    <!-- Title -->
    <div class="text-center space-y-3 animate-fade-in">
      <h1 class="text-3xl font-semibold tracking-tight">The cloudpoints</h1>
      <div class="flex items-center justify-center gap-3">
        <div class="h-px w-10 bg-air-200" />
        <MusicBars />
        <div class="h-px w-10 bg-air-200" />
      </div>
      <p class="text-xs font-mono text-air-400 uppercase tracking-[0.25em]">Return to Music</p>
    </div>

    <!-- Subtitle -->
    <p class="text-air-500 text-center mt-6 text-sm leading-relaxed max-w-sm animate-fade-in-delay-1">
      Your AI-powered music companion. Discover, explore, and experience music in a whole new way.
    </p>

    <!-- Waitlist Form -->
    <div class="w-full mt-8 animate-fade-in-delay-2">
      <WaitlistForm client:load />
    </div>
  </div>
</section>
